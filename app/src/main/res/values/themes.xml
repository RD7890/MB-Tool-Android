<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Android XML theme for the app window/activity.
        Compose draws its own UI, so this only needs to:
          1. Hide the action bar (NoActionBar)
          2. Allow edge-to-edge drawing
        Theme.Material.Light.NoActionBar is built into the platform (API 21+).
    -->
    <style name="Theme.MBTool" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
